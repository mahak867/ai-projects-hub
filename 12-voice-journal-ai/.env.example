# Copy this file to .env and fill in your values
# Never commit .env to git

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: S3 cloud sync — keeps journal.json backed up and accessible on all devices
# Requires: pip install boto3   and   AWS credentials (env vars or ~/.aws/credentials)
# JOURNAL_S3_BUCKET=my-journal-bucket
# JOURNAL_S3_KEY=journal.json           # optional, defaults to journal.json
# AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxx
# AWS_DEFAULT_REGION=ap-south-1
