# Copy this file to .env and fill in your values
# cp .env.example .env

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: VoyageAI key for production-quality semantic embeddings
# Without this, the RAG uses hash-based embeddings (demo quality only).
# Free key at https://www.voyageai.com — 10M tokens/month on the free tier.
# After setting this key, re-ingest all PDFs so embeddings are consistent.
# VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
