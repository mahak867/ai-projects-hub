# Copy this file to .env and fill in your values
# cp .env.example .env

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Brave Search API key for faster/more results (2,000 free/month)
# Without this, the app uses DuckDuckGo search automatically (free, no key needed).
# Get a free Brave key: https://brave.com/search/api/
# BRAVE_API_KEY=BSAxxxxxxxxxxxxxxxxxxxxxxxxxxxx
